# Formspree (https://formspree.io) endpoint URLs the contact and quote
# forms POST to directly from the browser. Get these from your Formspree
# dashboard for each form.
NEXT_PUBLIC_FORMSPREE_CONTACT_URL=https://formspree.io/f/your-contact-form-id
NEXT_PUBLIC_FORMSPREE_QUOTE_URL=https://formspree.io/f/your-quote-form-id
