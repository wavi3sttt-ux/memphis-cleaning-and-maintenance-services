# Resend (https://resend.com) API key used by /api/quote to email quote
# requests. Without this set, submissions are logged server-side only and
# the form still shows its success confirmation.
RESEND_API_KEY=

# Verified "from" address for outgoing quote emails. Defaults to Resend's
# shared testing domain if unset (onboarding@resend.dev) — replace with an
# address on a domain you've verified in Resend before going live.
RESEND_FROM_EMAIL=

# Overrides the "to" address for quote requests. Defaults to the address in
# src/lib/config.ts (CONTACT.email).
QUOTE_TO_EMAIL=

# Overrides the "to" address for general contact form messages. Defaults to
# the same address in src/lib/config.ts (CONTACT.email).
CONTACT_TO_EMAIL=
